# Required
BOT_TOKEN=your_telegram_bot_token_here

# Admin user IDs (comma-separated Telegram user IDs)
ADMIN_IDS=123456789,987654321

# Optional: restrict access to specific users (leave blank = open to everyone)
ALLOWED_USER_IDS=

# Optional: restrict access to specific chats/groups (leave blank = open to everyone)
ALLOWED_CHAT_IDS=

# Chat ID where daily/monthly reports are sent (0 = disabled)
REPORT_CHAT_ID=0

# PostgreSQL connection URL
# Railway will usually inject this automatically when a Postgres service is linked
# (also supports DATABASE_PRIVATE_URL / DATABASE_PUBLIC_URL / POSTGRES_URL)
DATABASE_URL=postgresql://postgres@localhost:5432/jizhang

# Timezone for dates and scheduled reports (IANA timezone name)
TZ=Asia/Shanghai

# Public base URL for Telegram webhook (Railway can use https://${RAILWAY_PUBLIC_DOMAIN})
WEBHOOK_BASE_URL=

# Webhook endpoint path
WEBHOOK_PATH=/telegram/webhook

# Optional webhook secret token (recommended)
WEBHOOK_SECRET_TOKEN=

# Fallback project name when message text does not include a project marker
DEFAULT_PROJECT_NAME=默认项目
